<!DOCTYPE html>
<html>
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <title>VMware Placement Report</title>
</head>

<body style="margin:0; padding:0; background-color:#f3f3f3; font-family:Arial, Helvetica, sans-serif; color:#333333;">

{% set report = vmware_placement_check | default({}) %}
{% set summary = report.get('summary', {}) %}
{% set distributions = report.get('group_distributions', []) %}
{% set quorum_risks = report.get('quorum_risk', []) %}
{% set avoidable = report.get('avoidable_colocation', []) %}
{% set unavoidable = report.get('unavoidable_colocation', []) %}
{% set mismatches = report.get('placement_mismatch', []) %}
{% set missing_vms = report.get('missing_from_vcenter', []) %}
{% set unknown_esx = report.get('unknown_esx', []) %}

{% set critical_count = (quorum_risks | length) + (avoidable | length) %}
{% set warning_count = (unavoidable | length) + (mismatches | length) + (missing_vms | length) + (unknown_esx | length) %}

{% if critical_count > 0 %}
{% set overall_status = 'CRITICAL' %}
{% set status_bg = '#f8d7da' %}
{% set status_colour = '#c00000' %}
{% elif warning_count > 0 %}
{% set overall_status = 'WARNING' %}
{% set status_bg = '#fff3cd' %}
{% set status_colour = '#856404' %}
{% else %}
{% set overall_status = 'HEALTHY' %}
{% set status_bg = '#e7f3e7' %}
{% set status_colour = '#217346' %}
{% endif %}

<table width="100%" border="0" cellspacing="0" cellpadding="0" bgcolor="#f3f3f3">
  <tr>
    <td align="center" style="padding:20px;">

      <table width="900" border="0" cellspacing="0" cellpadding="0"
             bgcolor="#ffffff"
             style="width:900px; max-width:900px; border-collapse:collapse; background-color:#ffffff;">
        <tr>
          <td style="padding:24px;">

            <h2 style="margin:0 0 8px 0; font-size:22px; color:#333333;">
              VMware ESX Placement Report
            </h2>

            <p style="margin:0 0 4px 0; font-size:14px; color:#555555;">
              Inventory:
              <strong>{{ inventory_name | default('N/A', true) }}</strong>
            </p>

            <p style="margin:0 0 4px 0; font-size:14px; color:#555555;">
              vCenter:
              <strong>{{ vcenter_name | default(vcenter_hostname | default('N/A', true), true) }}</strong>
              {% if vcenter_vm_folder | default('', true) %}
              &nbsp;&nbsp; Folder:
              <strong>{{ vcenter_vm_folder }}</strong>
              {% endif %}
            </p>

            <p style="margin:0 0 20px 0; font-size:14px; color:#555555;">
              Generated by:
              <strong>{{ launched_by_name | default('Ansible Automation Platform', true) }}</strong>
              {% if report_generated_at | default('', true) %}
              &nbsp;&nbsp; Generated:
              <strong>{{ report_generated_at }}</strong>
              {% endif %}
            </p>

            <!-- Overall status -->
            <table width="100%" border="0" cellspacing="0" cellpadding="10"
                   style="width:100%; border-collapse:collapse; margin-bottom:14px;">
              <tr>
                <td bgcolor="{{ status_bg }}"
                    style="border:1px solid #cccccc; font-size:18px; color:{{ status_colour }};">
                  <strong>{{ overall_status }}</strong>
                  {% if overall_status == 'CRITICAL' %}
                  &mdash; remediation is required for quorum or avoidable co-location findings.
                  {% elif overall_status == 'WARNING' %}
                  &mdash; review placement or inventory-data warnings.
                  {% else %}
                  &mdash; no placement or quorum issues were detected.
                  {% endif %}
                </td>
              </tr>
            </table>

            <!-- Summary -->
            <table width="100%" border="0" cellspacing="0" cellpadding="8"
                   style="width:100%; border-collapse:collapse; margin-bottom:20px;">
              <tr>
                <td width="20%" bgcolor="#e7f3e7"
                    style="border:1px solid #cccccc; font-size:15px;">
                  <strong>{{ summary.get('groups_checked', distributions | length) }}</strong><br>
                  groups checked
                </td>

                <td width="20%" bgcolor="#e7f3e7"
                    style="border:1px solid #cccccc; font-size:15px;">
                  <strong>{{ summary.get('esx_hosts_checked', 0) }}</strong><br>
                  ESX hosts
                </td>

                <td width="20%"
                    bgcolor="{% if quorum_risks | length > 0 %}#f8d7da{% else %}#e7f3e7{% endif %}"
                    style="border:1px solid #cccccc; font-size:15px;">
                  <strong>{{ quorum_risks | length }}</strong><br>
                  quorum risks
                </td>

                <td width="20%"
                    bgcolor="{% if avoidable | length > 0 %}#f8d7da{% else %}#e7f3e7{% endif %}"
                    style="border:1px solid #cccccc; font-size:15px;">
                  <strong>{{ avoidable | length }}</strong><br>
                  avoidable issues
                </td>

                <td width="20%"
                    bgcolor="{% if warning_count > 0 %}#fff3cd{% else %}#e7f3e7{% endif %}"
                    style="border:1px solid #cccccc; font-size:15px;">
                  <strong>{{ warning_count }}</strong><br>
                  warnings
                </td>
              </tr>
            </table>

            <!-- Group distribution -->
            <h3 style="margin:0 0 10px 0; font-size:18px; color:#333333;">
              Group Distribution
            </h3>

            {% if distributions | length > 0 %}
            <table width="100%" border="0" cellspacing="0" cellpadding="7"
                   style="width:100%; border-collapse:collapse; font-size:13px; margin-bottom:25px;">
              <tr bgcolor="#333333">
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Group</th>
                <th align="right" style="border:1px solid #cccccc; color:#ffffff;">Members</th>
                <th align="right" style="border:1px solid #cccccc; color:#ffffff;">Min / ESX</th>
                <th align="right" style="border:1px solid #cccccc; color:#ffffff;">Max / ESX</th>
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Status</th>
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Distribution</th>
              </tr>

              {% for item in distributions %}
              {% set spread = (item.maximum_per_esx | default(0) | int) - (item.minimum_per_esx | default(0) | int) %}
              {% set complete = item.evaluation_complete | default(false) %}
              {% set group_has_quorum = quorum_risks | selectattr('group', 'equalto', item.group) | list | length > 0 %}
              {% set group_has_avoidable = avoidable | selectattr('group', 'equalto', item.group) | list | length > 0 %}

              <tr bgcolor="{% if group_has_quorum or group_has_avoidable %}#fce8e8{% elif not complete or spread > 1 %}#fff8e1{% elif loop.index is even %}#f7f7f7{% else %}#ffffff{% endif %}">
                <td style="border:1px solid #cccccc;">
                  <strong>{{ item.group }}</strong>
                </td>
                <td align="right" style="border:1px solid #cccccc;">
                  {{ item.found_members | default(0) }}
                  {% if item.expected_members | default(0) != item.found_members | default(0) %}
                  / {{ item.expected_members | default(0) }} expected
                  {% endif %}
                </td>
                <td align="right" style="border:1px solid #cccccc;">
                  {{ item.minimum_per_esx | default(0) }}
                </td>
                <td align="right" style="border:1px solid #cccccc;">
                  {{ item.maximum_per_esx | default(0) }}
                </td>
                <td style="border:1px solid #cccccc;">
                  {% if group_has_quorum %}
                  <strong style="color:#c00000;">QUORUM RISK</strong>
                  {% elif group_has_avoidable %}
                  <strong style="color:#c00000;">REBALANCE</strong>
                  {% elif not complete %}
                  <strong style="color:#856404;">INCOMPLETE</strong>
                  {% elif spread > 1 %}
                  <strong style="color:#856404;">CHECK</strong>
                  {% else %}
                  <strong style="color:#217346;">BALANCED</strong>
                  {% endif %}
                </td>
                <td style="border:1px solid #cccccc; font-family:Consolas, 'Courier New', monospace; font-size:12px;">
                  {% for esx, count in item.counts | default({}) | dictsort %}
                  {{ esx }}={{ count }}{% if not loop.last %}, {% endif %}
                  {% endfor %}
                </td>
              </tr>
              {% endfor %}
            </table>
            {% else %}
            <p style="margin:0 0 25px 0; color:#555555;">
              No group-distribution information was returned.
            </p>
            {% endif %}

            <!-- Quorum risks -->
            {% if quorum_risks | length > 0 %}
            <h3 style="margin:30px 0 10px 0; font-size:18px; color:#c00000;">
              Quorum Risks
            </h3>

            {% for item in quorum_risks %}
            <a name="quorum-{{ loop.index }}" id="quorum-{{ loop.index }}"></a>
            <table width="100%" border="0" cellspacing="0" cellpadding="7"
                   style="width:100%; border-collapse:collapse; margin-bottom:25px; font-size:13px;">
              <tr bgcolor="#c00000">
                <th colspan="2" align="left"
                    style="border:1px solid #999999; color:#ffffff; font-size:15px;">
                  Group {{ item.group }} &mdash; quorum would be lost with {{ item.esx }}
                </th>
              </tr>
              <tr>
                <td width="190" bgcolor="#eeeeee" style="border:1px solid #cccccc;">
                  <strong>ESX host</strong>
                </td>
                <td style="border:1px solid #cccccc;">{{ item.esx }}</td>
              </tr>
              <tr>
                <td bgcolor="#eeeeee" style="border:1px solid #cccccc;">
                  <strong>VMs on ESX</strong>
                </td>
                <td style="border:1px solid #cccccc;">
                  {{ item.vms_on_esx | default([]) | join(', ') }}
                </td>
              </tr>
              <tr>
                <td bgcolor="#eeeeee" style="border:1px solid #cccccc;">
                  <strong>Quorum calculation</strong>
                </td>
                <td style="border:1px solid #cccccc;">
                  {{ item.total_members }} total members;
                  {{ item.quorum_required }} required;
                  {{ item.remaining_after_esx_loss }} would remain after loss of {{ item.esx }}.
                </td>
              </tr>
              <tr>
                <td bgcolor="#eeeeee" style="border:1px solid #cccccc;">
                  <strong>Recommended action</strong>
                </td>
                <td style="border:1px solid #cccccc; color:#c00000;">
                  Move at least one listed VM to a separate eligible ESX host, or increase the number
                  of independent failure domains before accepting this placement.
                </td>
              </tr>
            </table>
            {% endfor %}
            {% endif %}

            <!-- Avoidable co-location -->
            {% if avoidable | length > 0 %}
            <h3 style="margin:30px 0 10px 0; font-size:18px; color:#c00000;">
              Avoidable Same-Group Co-location
            </h3>

            {% for item in avoidable %}
            <table width="100%" border="0" cellspacing="0" cellpadding="7"
                   style="width:100%; border-collapse:collapse; margin-bottom:25px; font-size:13px;">
              <tr bgcolor="#c00000">
                <th colspan="2" align="left"
                    style="border:1px solid #999999; color:#ffffff; font-size:15px;">
                  Group {{ item.group }} &mdash; rebalancing is possible
                </th>
              </tr>
              <tr>
                <td width="190" bgcolor="#eeeeee" style="border:1px solid #cccccc;">
                  <strong>Group size</strong>
                </td>
                <td style="border:1px solid #cccccc;">
                  {{ item.member_count }} VMs across {{ item.esx_count }} ESX hosts
                </td>
              </tr>
              <tr>
                <td bgcolor="#eeeeee" style="border:1px solid #cccccc;">
                  <strong>Overloaded source hosts</strong>
                </td>
                <td style="border:1px solid #cccccc;">
                  {% for source in item.source_hosts | default([]) %}
                  <strong>{{ source.esx }}</strong>
                  ({{ source.count }}: {{ source.vms | join(', ') }}){% if not loop.last %}<br>{% endif %}
                  {% else %}
                  Not returned
                  {% endfor %}
                </td>
              </tr>
              <tr>
                <td bgcolor="#eeeeee" style="border:1px solid #cccccc;">
                  <strong>Possible destinations</strong>
                </td>
                <td style="border:1px solid #cccccc;">
                  {% for destination in item.possible_destination_hosts | default([]) %}
                  {{ destination.esx }} (currently {{ destination.count }}){% if not loop.last %}, {% endif %}
                  {% else %}
                  Not returned
                  {% endfor %}
                </td>
              </tr>
              <tr>
                <td bgcolor="#eeeeee" style="border:1px solid #cccccc;">
                  <strong>Current distribution</strong>
                </td>
                <td style="border:1px solid #cccccc; font-family:Consolas, 'Courier New', monospace; font-size:12px;">
                  {% for esx, count in item.counts | default({}) | dictsort %}
                  {{ esx }}={{ count }}{% if not loop.last %}, {% endif %}
                  {% endfor %}
                </td>
              </tr>
            </table>
            {% endfor %}
            {% endif %}

            <!-- Predictable placement mismatches -->
            {% if mismatches | length > 0 %}
            <h3 style="margin:30px 0 10px 0; font-size:18px; color:#856404;">
              Predictable Placement Mismatches
            </h3>

            <table width="100%" border="0" cellspacing="0" cellpadding="7"
                   style="width:100%; border-collapse:collapse; font-size:13px; margin-bottom:25px;">
              <tr bgcolor="#333333">
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Group</th>
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">VM</th>
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Current ESX</th>
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Expected ESX</th>
              </tr>
              {% for item in mismatches %}
              <tr bgcolor="{% if loop.index is even %}#f7f7f7{% else %}#ffffff{% endif %}">
                <td style="border:1px solid #cccccc;">{{ item.group }}</td>
                <td style="border:1px solid #cccccc;"><strong>{{ item.vm }}</strong></td>
                <td style="border:1px solid #cccccc;">{{ item.actual_esx | default('Unknown', true) }}</td>
                <td style="border:1px solid #cccccc;">{{ item.expected_esx }}</td>
              </tr>
              {% endfor %}
            </table>
            {% endif %}

            <!-- Unavoidable co-location -->
            {% if unavoidable | length > 0 %}
            <h3 style="margin:30px 0 10px 0; font-size:18px; color:#856404;">
              Unavoidable but Balanced Co-location
            </h3>

            <p style="margin:0 0 10px 0; font-size:13px; color:#555555;">
              These groups contain more VMs than available ESX hosts, or otherwise require
              co-location, but the current per-host spread differs by no more than one.
            </p>

            <table width="100%" border="0" cellspacing="0" cellpadding="7"
                   style="width:100%; border-collapse:collapse; font-size:13px; margin-bottom:25px;">
              <tr bgcolor="#333333">
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Group</th>
                <th align="right" style="border:1px solid #cccccc; color:#ffffff;">VMs</th>
                <th align="right" style="border:1px solid #cccccc; color:#ffffff;">ESX Hosts</th>
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Duplicate Locations</th>
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Distribution</th>
              </tr>
              {% for item in unavoidable %}
              <tr bgcolor="{% if loop.index is even %}#f7f7f7{% else %}#ffffff{% endif %}">
                <td style="border:1px solid #cccccc;"><strong>{{ item.group }}</strong></td>
                <td align="right" style="border:1px solid #cccccc;">{{ item.member_count }}</td>
                <td align="right" style="border:1px solid #cccccc;">{{ item.esx_count }}</td>
                <td style="border:1px solid #cccccc;">
                  {% for duplicate in item.duplicate_hosts | default([]) %}
                  {{ duplicate.esx }}: {{ duplicate.vms | join(', ') }}{% if not loop.last %}<br>{% endif %}
                  {% endfor %}
                </td>
                <td style="border:1px solid #cccccc; font-family:Consolas, 'Courier New', monospace; font-size:12px;">
                  {% for esx, count in item.counts | default({}) | dictsort %}
                  {{ esx }}={{ count }}{% if not loop.last %}, {% endif %}
                  {% endfor %}
                </td>
              </tr>
              {% endfor %}
            </table>
            {% endif %}

            <!-- Data quality -->
            {% if missing_vms | length > 0 or unknown_esx | length > 0 %}
            <h3 style="margin:30px 0 10px 0; font-size:18px; color:#856404;">
              Inventory and vCenter Data Warnings
            </h3>

            {% if missing_vms | length > 0 %}
            <h4 style="margin:0 0 8px 0; font-size:15px; color:#333333;">
              Inventory VMs not found in the queried vCenter folder
            </h4>

            <table width="100%" border="0" cellspacing="0" cellpadding="7"
                   style="width:100%; border-collapse:collapse; font-size:13px; margin-bottom:20px;">
              <tr bgcolor="#333333">
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Group</th>
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Inventory Host</th>
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Expected vCenter Name</th>
              </tr>
              {% for item in missing_vms %}
              <tr bgcolor="{% if loop.index is even %}#f7f7f7{% else %}#ffffff{% endif %}">
                <td style="border:1px solid #cccccc;">{{ item.group }}</td>
                <td style="border:1px solid #cccccc;">{{ item.inventory_host }}</td>
                <td style="border:1px solid #cccccc;">{{ item.vcenter_name }}</td>
              </tr>
              {% endfor %}
            </table>
            {% endif %}

            {% if unknown_esx | length > 0 %}
            <h4 style="margin:0 0 8px 0; font-size:15px; color:#333333;">
              vCenter ESX names not matched to the esxp inventory group
            </h4>

            <table width="100%" border="0" cellspacing="0" cellpadding="7"
                   style="width:100%; border-collapse:collapse; font-size:13px; margin-bottom:20px;">
              <tr bgcolor="#333333">
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Group</th>
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">VM</th>
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">vCenter VM Name</th>
                <th align="left" style="border:1px solid #cccccc; color:#ffffff;">Reported ESX</th>
              </tr>
              {% for item in unknown_esx %}
              <tr bgcolor="{% if loop.index is even %}#f7f7f7{% else %}#ffffff{% endif %}">
                <td style="border:1px solid #cccccc;">{{ item.group }}</td>
                <td style="border:1px solid #cccccc;">{{ item.vm }}</td>
                <td style="border:1px solid #cccccc;">{{ item.vcenter_name }}</td>
                <td style="border:1px solid #cccccc;">{{ item.reported_esx | default('Not returned', true) }}</td>
              </tr>
              {% endfor %}
            </table>
            {% endif %}
            {% endif %}

            {% if critical_count == 0 and warning_count == 0 %}
            <table width="100%" border="0" cellspacing="0" cellpadding="12"
                   style="width:100%; border-collapse:collapse; margin-top:25px;">
              <tr>
                <td bgcolor="#e7f3e7"
                    style="border:1px solid #cccccc; color:#217346; font-size:15px;">
                  <strong>No placement exceptions were found.</strong>
                  All evaluated groups are balanced, no quorum-risk co-location was detected,
                  and the vCenter data matched the inventory.
                </td>
              </tr>
            </table>
            {% endif %}

            {% if aap_job_url | default('', true) %}
            <p style="margin:25px 0 0 0; font-size:13px; color:#555555;">
              <a href="{{ aap_job_url }}"
                 style="color:#0563c1; text-decoration:underline;">
                View the AAP job that generated this report
              </a>
            </p>
            {% endif %}

            <p style="margin:25px 0 0 0; padding-top:15px; border-top:1px solid #dddddd;
                      font-size:12px; color:#777777;">
              This report reflects the placement returned by vCenter at the time the automation ran.
              Quorum checks are applied only to groups listed in <strong>quorum_groups</strong>.
            </p>

          </td>
        </tr>
      </table>

    </td>
  </tr>
</table>

</body>
</html>
